# ── Gitcoin Passport ────────────────────────────────────────────────────────
VITE_GITCOIN_API_KEY=
VITE_GITCOIN_SCORER_ID=

# ── Solana RPC ───────────────────────────────────────────────────────────────
VITE_SOLANA_RPC_URL=
VITE_SOLANA_RPC_FALLBACK=
VITE_SOLANA_WS_URL=
SOLANA_RPC_URL=
SOLANA_WS_URL=

# ── Airdrop / Claim (server-side only) ───────────────────────────────────────
AIRDROP_TOKEN_MINT=
AIRDROP_AMOUNT=10
CLAIM_TREASURY_SECRET=
CAMPAIGN_ID=devnet-default

# ── Eligibility thresholds (keep frontend + backend in sync) ─────────────────
HUMAN_MIN_SCORE=5
MIN_WALLET_AGE_DAYS=1
VITE_HUMAN_MIN_SCORE=5
VITE_MIN_WALLET_AGE_DAYS=1
VITE_MIN_SOL_FOR_CLAIM=0.000005

# ── GitHub OAuth (device flow — create at github.com/settings/applications) ──
# Client ID is safe to expose in VITE_ vars (public OAuth app)
VITE_GITHUB_CLIENT_ID=
# Optional: set on server side for additional verification
GITHUB_CLIENT_ID=
